---
// huhugerman.com — Lista de espera
// Stack: Astro (static) + Kit embed
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>huhuGERMAN — Lista de espera</title>
  <meta name="description" content="No el alemán del libro. El alemán de la calle. Lista de espera abierta." />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@1,900&family=Barlow:wght@300;400;500&family=Space+Mono:wght@400;700&display=swap"
    rel="stylesheet"
  />

  <style>
    /* ── Tokens ── */
    :root {
      --bvg:        #F0D722;
      --bvg-dim:    #C4AE0A;
      --bvg-dark:   #3D3500;
      --black:      #080808;
      --concrete:   #1A1A1A;
      --graffiti:   #2A2A2A;
      --white:      #F2F2F0;
      --gray:       #888880;

      --f-display: 'Barlow Condensed', sans-serif;
      --f-body:    'Barlow', sans-serif;
      --f-mono:    'Space Mono', monospace;
    }

    /* ── Reset ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      background: var(--black);
      color: var(--white);
      font-family: var(--f-body);
      font-weight: 400;
      -webkit-font-smoothing: antialiased;
      scroll-behavior: smooth;
    }

    /* ── Utilidades ── */
    .mono   { font-family: var(--f-mono); }
    .yellow { color: var(--bvg); }

    /* ── Barra U-Bahn superior ── */
    .ubahn-bar {
      height: 4px;
      background: var(--bvg);
      width: 100%;
      position: fixed;
      top: 0;
      left: 0;
      z-index: 100;
    }

    /* ── Nav mínimo ── */
    nav {
      position: fixed;
      top: 4px;
      left: 0;
      right: 0;
      z-index: 99;
      padding: 1.25rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(8,8,8,0.92);
      backdrop-filter: blur(8px);
    }

    .nav-logo {
      font-family: var(--f-display);
      font-style: italic;
      font-weight: 900;
      font-size: 1.5rem;
      letter-spacing: -0.02em;
      color: var(--bvg);
      text-decoration: none;
    }

    .nav-cta {
      font-family: var(--f-mono);
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--black);
      background: var(--bvg);
      padding: 0.5rem 1.25rem;
      text-decoration: none;
      transition: background 0.2s ease;
    }
    .nav-cta:hover { background: var(--white); }

    /* ── Hero ── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 8rem 2rem 4rem;
      max-width: 900px;
      margin: 0 auto;
      position: relative;
    }

    .hero-label {
      font-family: var(--f-mono);
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: var(--bvg);
      margin-bottom: 2rem;
      opacity: 0;
      animation: fadeUp 0.6s ease 0.1s forwards;
    }

    .hero-headline {
      font-family: var(--f-display);
      font-style: italic;
      font-weight: 900;
      font-size: clamp(3.5rem, 10vw, 7.5rem);
      line-height: 0.92;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      color: var(--white);
      margin-bottom: 1rem;
      opacity: 0;
      animation: fadeUp 0.6s ease 0.25s forwards;
    }

    /* La frase tachada — animación de erosión */
    .tachado {
      position: relative;
      display: inline-block;
      color: var(--gray);
    }
    .tachado::after {
      content: '';
      position: absolute;
      left: 0;
      top: 50%;
      height: 3px;
      background: var(--bvg);
      width: 0;
      animation: tachar 0.8s ease 1.2s forwards;
    }
    @keyframes tachar {
      to { width: 100%; }
    }

    .hero-headline .calle {
      color: var(--bvg);
      display: block;
    }

    .hero-sub {
      font-family: var(--f-body);
      font-weight: 300;
      font-size: clamp(1rem, 2.5vw, 1.25rem);
      color: var(--gray);
      max-width: 520px;
      line-height: 1.65;
      margin-top: 2rem;
      margin-bottom: 3rem;
      opacity: 0;
      animation: fadeUp 0.6s ease 0.4s forwards;
    }

    /* ── Divisor U-Bahn ── */
    .ubahn-divisor {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin: 2rem 0 3.5rem;
      opacity: 0;
      animation: fadeUp 0.6s ease 0.5s forwards;
    }
    .ubahn-divisor::before,
    .ubahn-divisor::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--graffiti);
    }
    .ubahn-divisor span {
      font-family: var(--f-mono);
      font-size: 0.6rem;
      color: var(--bvg);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    /* ── Kit form container ── */
    .kit-wrapper {
      opacity: 0;
      animation: fadeUp 0.6s ease 0.6s forwards;
    }

    /* ── Pie del hero ── */
    .hero-foot {
      margin-top: 3rem;
      display: flex;
      align-items: center;
      gap: 2rem;
      opacity: 0;
      animation: fadeUp 0.6s ease 0.75s forwards;
    }

    .hero-foot-item {
      font-family: var(--f-mono);
      font-size: 0.6rem;
      color: var(--gray);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .hero-foot-item::before {
      content: '—';
      color: var(--bvg);
    }

    /* ── Silueta Berlín ── */
    .berlin-silhouette {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      height: 120px;
      pointer-events: none;
      z-index: 0;
      opacity: 0.06;
    }

    /* ── Footer ── */
    footer {
      border-top: 1px solid var(--graffiti);
      padding: 2rem;
      text-align: center;
      position: relative;
      z-index: 1;
    }

    .footer-tagline {
      font-family: var(--f-display);
      font-style: italic;
      font-weight: 900;
      font-size: 1.1rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--gray);
      margin-bottom: 0.75rem;
    }

    .footer-autor {
      font-family: var(--f-mono);
      font-size: 0.6rem;
      color: var(--graffiti);
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    /* ── Animación base ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Responsive ── */
    @media (max-width: 600px) {
      nav { padding: 1rem 1.25rem; }
      .hero { padding: 7rem 1.25rem 3rem; }
      .hero-foot { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
    }
  </style>
</head>
<body>

  <div class="ubahn-bar"></div>

  <nav>
    <a href="/" class="nav-logo">huhuGERMAN</a>
    <a href="#lista" class="nav-cta">Lista de espera</a>
  </nav>

  <main>
    <section class="hero">
      <p class="hero-label mono">Lista de espera · Abriendo pronto</p>
      <h1 class="hero-headline">
        No el alemán<br>
        <span class="tachado">del libro.</span>
        <span class="calle">De la calle.</span>
      </h1>
      <p class="hero-sub">
        Aprendiste alemán durante años. Llegaste a Berlín y algo no cuadraba.
        huhuGERMAN trabaja exactamente eso — el alemán rápido, reducido,
        lleno de partículas que nadie te enseñó.
      </p>
      <div class="ubahn-divisor">
        <span>U8 · Nachtfahrt · CDMX → BER</span>
      </div>
      <div class="kit-wrapper" id="lista">
        <script async data-uid="c5ade38b05" src="https://huhugerman.kit.com/c5ade38b05/index.js"></script>
      </div>
      <div class="hero-foot">
        <span class="hero-foot-item">Sin precio todavía</span>
        <span class="hero-foot-item">Sin compromiso</span>
        <span class="hero-foot-item">Solo tu lugar reservado</span>
      </div>
    </section>
  </main>

