    .loader-words span:nth-child(1){color:var(--danger)}
    .loader-words span:nth-child(2){color:var(--warn)}
    .loader-words span:nth-child(3){color:var(--acid)}
    .loader-sub {
      font-family: var(--font-mono);
      text-transform: uppercase; letter-spacing: .16em;
      font-size: .76rem; color: var(--acid);
      margin-top: 1.1rem;
    }
    .loader-track {
      width: min(300px, 72vw); height: 2px;
      background: rgba(255,255,255,.1);
      overflow: hidden; border-radius: 999px;
      margin: 1rem auto 0;
